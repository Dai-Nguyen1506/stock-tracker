# --- KẾT NỐI DATABASE ---
# Cassandra
CASSANDRA_HOST=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=market_data

# Redis
REDIS_URL=redis://localhost:6379

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# PostgreSQL (Benchmarking)
PG_URL=postgresql://user:password@localhost:5432/market_data

# --- CẤU HÌNH ỨNG DỤNG ---
APP_ENV=development
APP_PORT=8000

# --- API KEYS (ĐIỀN VÀO ĐÂY) ---
# Alpaca (Tin tức & Dữ liệu thị trường)
ALPACA_API_KEY_ID=your_alpaca_key_here
ALPACA_API_SECRET_KEY=your_alpaca_secret_here

# AI Chatbot (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here